// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Ingredient {
  id               Int               @id @default(autoincrement())
  shop             String
  name             String
  category         String
  purchaseWeight   Float
  purchasePrice    Float
  stockWeight      Float             @default(0)
  minimumStock     Float             @default(0)
  supplier         String?
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  aliases          IngredientAlias[]
  orderIngredients OrderIngredient[]
  stockMovements   StockMovement[]

  @@unique([shop, name])
  @@index([shop])
}

model Order {
  id                Int                       @id @default(autoincrement())
  shop              String
  shopifyOrderId    String
  orderName         String
  createdAtShopify  DateTime
  paymentStatus     String?
  fulfillmentStatus String?
  productionStatus  String                    @default("NEW")
  priority          Int                       @default(0)
  blockedReason     String?
  internalNote      String?
  totalWeight       Float                     @default(0)
  totalPriceCents   Int                       @default(0)
  currencyCode      String                    @default("EUR")
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  shippingAddress   String?
  shippingMethod    String?
  trackingNumber    String?
  trackingUrl       String?
  shippingCarrier   String?
  labelStatus       String                    @default("MISSING")
  rawData           String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  lineItems         OrderLineItem[]
  ingredients       OrderIngredient[]
  productionOrder   ProductionOrder?
  statusHistory     ProductionStatusHistory[]
  stockMovements    StockMovement[]

  @@unique([shop, shopifyOrderId])
  @@index([shop, productionStatus])
  @@index([shop, createdAtShopify])
}

model OrderLineItem {
  id                Int               @id @default(autoincrement())
  shop              String
  shopifyLineItemId String
  orderId           Int
  title             String
  quantity          Int
  unitPriceCents    Int               @default(0)
  currencyCode      String            @default("EUR")
  configuration     String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ingredients       OrderIngredient[]

  @@unique([shop, shopifyLineItemId])
  @@index([orderId])
}

model OrderIngredient {
  id            Int           @id @default(autoincrement())
  orderId       Int
  lineItemId    Int
  ingredientId  Int?
  name          String
  category      String
  gramsPerMix   Float?
  totalGrams    Float?
  mappingStatus String        @default("UNKNOWN")
  costCents     Int?
  checked       Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lineItem      OrderLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  ingredient    Ingredient?   @relation(fields: [ingredientId], references: [id], onDelete: SetNull)

  @@unique([lineItemId, name])
  @@index([orderId])
  @@index([ingredientId])
}

model ProductionOrder {
  id          Int       @id @default(autoincrement())
  orderId     Int       @unique
  status      String    @default("NEW")
  startedAt   DateTime?
  packedAt    DateTime?
  readyAt     DateTime?
  completedAt DateTime?
  blockedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ProductionStatusHistory {
  id             Int      @id @default(autoincrement())
  shop           String
  orderId        Int
  previousStatus String
  newStatus      String
  actor          String?
  note           String?
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([shop, orderId, createdAt])
}

model StockMovement {
  id             Int        @id @default(autoincrement())
  shop           String
  ingredientId   Int
  orderId        Int?
  type           String
  quantityGrams  Float
  idempotencyKey String
  note           String?
  createdAt      DateTime   @default(now())
  ingredient     Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  order          Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([shop, idempotencyKey])
  @@index([shop, ingredientId])
  @@index([orderId])
}

model WebhookEvent {
  id          Int       @id @default(autoincrement())
  shop        String
  webhookId   String
  topic       String
  status      String    @default("RECEIVED")
  error       String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([shop, webhookId])
  @@index([shop, topic, createdAt])
}

model IngredientAlias {
  id           Int        @id @default(autoincrement())
  shop         String
  alias        String
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([shop, alias])
  @@index([shop])
  @@index([ingredientId])
}

model AiAgent {
  id           Int             @id @default(autoincrement())
  shop         String
  slug         String
  name         String
  role         String
  description  String
  goals        String
  instructions String
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tasks        AiTask[]
  activities   AiActivityLog[]

  @@unique([shop, slug])
  @@index([shop, active])
}

model AiTask {
  id           Int             @id @default(autoincrement())
  shop         String
  agentId      Int
  title        String
  prompt       String
  context      String?
  status       String          @default("DRAFT")
  priority     Int             @default(0)
  requestedBy  String?
  scheduledFor DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  agent        AiAgent         @relation(fields: [agentId], references: [id], onDelete: Restrict)
  results      AiResult[]
  approvals    AiApproval[]
  activities   AiActivityLog[]

  @@index([shop, agentId, status])
  @@index([shop, createdAt])
}

model AiResult {
  id             Int          @id @default(autoincrement())
  shop           String
  taskId         Int
  summary        String
  content        String
  structuredData String?
  model          String?
  tokenUsage     Int?
  estimatedCost  Decimal?
  status         String       @default("DRAFT")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  task           AiTask       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  approvals      AiApproval[]

  @@index([shop, taskId, status])
}

model AiApproval {
  id              Int       @id @default(autoincrement())
  shop            String
  taskId          Int
  resultId        Int
  actionType      String    @default("CONTENT_REVIEW")
  status          String    @default("PENDING")
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  task            AiTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  result          AiResult  @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@unique([shop, resultId, actionType])
  @@index([shop, status])
}

model AiActivityLog {
  id        Int      @id @default(autoincrement())
  shop      String
  agentId   Int?
  taskId    Int?
  action    String
  details   String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())
  agent     AiAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)
  task      AiTask?  @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([shop, createdAt])
  @@index([taskId])
}

model AiSettings {
  id               Int      @id @default(autoincrement())
  shop             String   @unique
  approvalRequired Boolean  @default(true)
  maxTasksPerDay   Int      @default(10)
  usageLimitCents  Int      @default(0)
  loggingEnabled   Boolean  @default(true)
  autoRunEnabled   Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
